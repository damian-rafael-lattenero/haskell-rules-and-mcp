{
  "name": "haskell-ghci-mcp",
  "version": "0.1.0",
  "description": "MCP server providing persistent GHCi session for incremental Haskell type-checking",
  "type": "module",
  "main": "dist/index.js",
  "files": [
    "dist",
    "rules",
    "vendor-tools",
    "package.json"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "test:all": "npm run test && npm run test:integration && npm run test:e2e",
    "tools:update-manifest": "node dist/scripts/update-bundled-tools.js",
    "tools:download": "node dist/scripts/download-bundled-tools.js",
    "tools:validate": "node dist/scripts/validate-bundled-tools.js",
    "tools:test": "node dist/scripts/test-bundled-tool.js",
    "tools:setup": "./scripts/setup-bundled-tools.sh"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.1"
  }
}
