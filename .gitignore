**/dist-newstyle/
.idea/
*.hi
*.o
*.dyn_hi
*.dyn_o

# cabal-generated, always local-only. `cabal freeze` is used by CI as a
# cache-key input; we don't commit the resulting plan.
**/cabal.project.freeze
**/cabal.project.local
**/cabal.project.local~

# Disposable playground projects
playground/smoke-test/
playground/expr-evaluator/

# Property store (generated at runtime by ghci_quickcheck)
**/.haskell-flows/

# Local MCP config (may contain personal paths/env). Copy from .mcp.example.json
.mcp.json
