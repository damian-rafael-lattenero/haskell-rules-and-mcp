**/dist-newstyle/
.idea/
*.hi
*.o
*.dyn_hi
*.dyn_o

# cabal-generated, always local-only. `cabal freeze` is used by CI as a
# cache-key input; we don't commit the resulting plan.
**/cabal.project.freeze
**/cabal.project.local
**/cabal.project.local~

# MCP server build artifacts
mcp-server/node_modules/
mcp-server/dist/

# Smoke test results (local, regenerated per run)
mcp-server/test-results/*.md

# Disposable playground projects
playground/smoke-test/

# Property store (generated at runtime by ghci_quickcheck)
**/.haskell-flows/

# Local MCP config (may contain personal paths/env). Copy from .mcp.example.json
.mcp.json

# Vendor tools (large binaries) — downloaded by auto-download at runtime.
# Only the manifest and README are tracked.
mcp-server/vendor-tools/hlint/
mcp-server/vendor-tools/fourmolu/
mcp-server/vendor-tools/ormolu/
mcp-server/vendor-tools/hls/
playground/expr-evaluator/
